arr = [10 20 30 40 50]

# Conditional expressions that include range-indexed array operands.
sum = 0
# Self-reference: RHS must read from the same temp slot the IF branch writes.
sum = 2 > 1 sum + arr[1:4]
"CondRangeSelectionExprTrue: -sum"
sum = 1 > 2 sum + arr[2:5]
"CondRangeSelectionExprFalseExisting: -sum"
newSum = 1 > 2 0 + arr[1:4]
"CondRangeSelectionExprFalseNew: -newSum"
newSumTrue = 2 > 1 0 + arr[1:4]
"CondRangeSelectionExprTrueNew: -newSumTrue"

sx = 5
sx = 2 > 1 sx + 10
"CondSelfRefScalarTrue: -sx"
sx = 2 > 3 sx + 1
"CondSelfRefScalarFalseExisting: -sx"

# Conditional expressions that include prefix operations.
x = 5
y = 1 > 0 3x + -x
"CondPrefixTrue: -y"
y = 1 > 2 3x + -x
"CondPrefixFalseExisting: -y"
z = 1 > 2 3x + -x
"CondPrefixFalseNew: -z"

pr = 7
pr = 1 > 0 0 + -arr[1:4]
"CondPrefixRangeSelectionTrue: -pr"
pr = 1 > 2 0 + -arr[1:2]
"CondPrefixRangeSelectionFalseExisting: -pr"
k = 1 > 2 0 + -arr[1:4]
"CondPrefixRangeSelectionFalseNew: -k"
