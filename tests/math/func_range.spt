i = 0:5
bareRange = Square(i)
"Square of bare 0:5: -bareRange"

rangeExpression = Square(i + 1)
"Square of 0:5 + 1: -rangeExpression"

j = 0:5
twoBareRanges = SumSquares(i, j)
"SumSquares of bare 0:5, 0:5: -twoBareRanges"

mixedRangeExpression = SumSquares(i, (j + 1) / (j + 2))
"SumSquares of 0:5 and range expression: -mixedRangeExpression"
