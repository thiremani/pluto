i = 0:5
arr = [i]
literalSelection = Square(arr[0:2])
"Square of [0:5][0:2] final selection: -literalSelection"

j = 1:3
offsetSelection = Square(arr[j + 1])
"Square of [0:5][0:2 + 1] final selection: -offsetSelection"

nestedSelections = SumSquares(arr[i], arr[j])
"SumSquares of arr[0:5], arr[1:3] nested selections: -nestedSelections"

literalSelections = SumSquares([0 1 2 3][0:2], [1 2 3 4][j + 1])
"SumSquares of [0 1 2 3][0:2], [1 2 3 4][1:3 + 1] final selection: -literalSelections"
