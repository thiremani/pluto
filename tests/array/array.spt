arrInt =
[
  1 2 3 4
]
arrInt
"arr is -arrInt"
arrIntWidth = 4
"arr int padded: |-arrInt%(-arrIntWidth)d|"
"arr int hex: -arrInt%#x"
arrChars = [65 0 66 256]
"arr chars: |-arrChars%5c|"

arrFloat =
[
  1.5 -2.5 3 4.25
]
arrFloat
"arr is -arrFloat"
"arr float fixed: |-arrFloat%7.2f|"
arrWidth = 7
arrPrecision = 1
"arr float dynamic: |-arrFloat%(-arrWidth).(-arrPrecision)f|"

arrStr =
[
  "foo" "bar" "baz"
]
arrStr
"arr is -arrStr"
"arr str raw: -arrStr%s"

arrStrQuoted = ["hello" "hello world" "" "say \"hi\"" "slash\\" "line\nbreak" "tab\tstop" "carriage\rreturn" "back\bspace" "form\ffeed" "escape\x1b" "dash-word" "π"]
"quoted arr is -arrStrQuoted"

# inline vector (no newline inside)
arr2 = [1 2 3 4]
arr2
"arr2 is -arr2"

# bracket on same line, then rows on next line(s)
arr3 = [
  1.1 2.3 4 2.1
]
arr3
"arr3 is -arr3"

matrix =
[
    1 2.5
    3 4
]
"matrix: -matrix"

scores =
[
    :Name Score
    "Ada" 10
    "Lin" 12
]
"table: -scores"
scoreColumn = scores.Score
"table scores: -scoreColumn"
scores =
[
    :Name Score
    "Mae" 20
]
"replacement table: -scores"
"saved table scores: -scoreColumn"

inferredTable =
[
    1 "a"
    2 "b"
]
"inferred table: -inferredTable"
