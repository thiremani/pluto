s = "hello world"
s

t = "abcd"
s, t

x = 5
six = 6
"x = -x, six = -six"
y = 5 * x
"x - -x", "y - -y, and negative numbers are -1, -2, -3"
z = 8.73
a = 1.23
"Preceding with blanks: -x%10d"

x = 42
two = 2
"Preceding with zeros -x%010d and different radices -x%o -x%x -x%#o -x%#x \n"
"Floats: -z%4.2f -z%+.0e -a%E"
"Width: -x%5d"
"Percent: -x%%"
"Percentage text: -x\% complete"
"Separated percent: -x %"
n = 30
"Value: -n%%(5)d."
"Profit is -x%%(Higher than last year"
"Profit is -x%% (Higher than last year)"
"Space sign:-x% d|-z% .2f"
"Multiple percentage: % -z%4.2f% %"
"Variable width -x%(-six)d"
"Variable precision -z%8.(-two)f -a%(-six).2f and -z%(-six).(-two)f%"
"Unresolved marker: -missing%(-six)d"

var = 22
"Var is -var%d, x is", x, "Now y is -y%8d and two is", two

eager = 123
msg = "eager = -eager%4d"
eager = 999
msg, eager

# Heap string literals with markers
name = "world"
heapMsg = "hello -name"
heapMsg
"quoted heap: -heapMsg%q"

quoteText = "hello \"world\"\\path\nnext\tcol"
"quoted static: -quoteText%q"
quotePrecision = 2
"quoted precision: -quoteText%.2q"
"quoted dynamic precision: -quoteText%.(-quotePrecision)q"
"quoted width precision: |-quoteText%8.2q|"
quotedStored = "-quoteText%.2q"
"quoted stored precision: -quotedStored"
quoteEscaped = "a\"b"
"quoted escaped precision: -quoteEscaped%.2q"
quoteUnicode = "πx"
"quoted unicode byte precision: -quoteUnicode%.2q"

markerName = 99
literalMarker = "\-markerName"
hexLiteralMarker = "\x2dmarkerName"
"literal markers: -literalMarker -hexLiteralMarker; value: -markerName"
unicodeLiteralMarker = "\u002dmarkerName"
wideUnicodeLiteralMarker = "\U0000002dmarkerName"
"unicode literal markers: -unicodeLiteralMarker -wideUnicodeLiteralMarker"
markerPrefix = 7
markerPrefixTail = 88
escapedMarkerStart = "-\x6darkerName"
escapedMarkerTail = "-markerPrefix\x54ail"
"escaped marker parts: -escapedMarkerStart -escapedMarkerTail; full: -markerPrefixTail"
specifierText = "hello"
"escaped specifier: -specifierText\x25q"
"unicode escaped specifier: -specifierText\u0025q -specifierText\U00000025q"
"quoted marker: -literalMarker%q"

unicodeEscapes = "\xff \u03c0 \U0001f680"
"unicode escapes: -unicodeEscapes"

# Heap string with format specifiers
num = 42
heapFmt = "number is -num%05d"
heapFmt

# Print heap string with markers directly
"heap print: -name"

# Owned string without markers
rawHeap = "no markers here"
rawHeap
rawHeap = rawHeap ⊕ "abc"
rawHeap

# Reassign heap string with markers
heapMsg = "goodbye -name"
heapMsg
